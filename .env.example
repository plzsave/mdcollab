# コピーして .env を作る（.env は gitignore 済み・コミット禁止）。
# scripts/gen-wrangler.sh がこの値から wrangler.toml を生成する。
# CI(GitHub Actions)では同じ値を repo の Variables / Secrets に登録する
# （非秘密は Variables、トークン等の秘密は Secrets）。

# Worker の公開 URL。独自ドメインなら https://md.example.com、
# まだなら https://<worker>.<subdomain>.workers.dev
BASE_URL=https://mdcollab-api.your-subdomain.workers.dev

# 独自ドメインを使う場合のみ設定（設定すると workers_dev=false + custom_domain route が付く）。
# 未設定なら workers.dev で動く。
CUSTOM_DOMAIN=

# R2(S3互換)。エンドポイントは https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=your-r2-bucket
S3_REGION=auto

# `wrangler hyperdrive create <name> --connection-string=...` の出力 id
HYPERDRIVE_ID=your-hyperdrive-id

# wrangler/Cloudflare API 用。`wrangler deploy` がアカウント解決に使う。
CLOUDFLARE_ACCOUNT_ID=your-account-id

# 秘密(トークン)。ローカルで wrangler login 済みなら不要。CI では Secrets に入れる。
# CLOUDFLARE_API_TOKEN=...
