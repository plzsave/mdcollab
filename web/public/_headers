# Cloudflare Workers Assets が解釈するレスポンスヘッダ（vite が dist 直下へコピー）。
# SPA(HTML/JS/CSS) のレスポンスにセキュリティヘッダを付与する。/api/* は Worker 側なので対象外。
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'
