# コピーして terraform.tfvars を作る（terraform.tfvars は .gitignore 済み・コミット禁止）。
# 個人のアカウント値はここに書く（リポジトリには入らない）。
# 環境変数で渡す場合は TF_VAR_<name>=... でも可。

# Cloudflare アカウント ID
account_id = "REPLACE_ME"

# R2 バケット（MD 本体ストア）
r2_bucket_name = "your-r2-bucket"
# r2_location  = "apac"   # apac / wnam / enam / weur / eeur（既定 apac）

# Hyperdrive origin（Postgres / 例: Neon）
neon_host     = "your-db-host.example.neon.tech"
# neon_database = "neondb"        # 既定あり
# neon_user     = "neondb_owner"  # 既定あり
# neon_port     = 5432            # 既定あり
neon_password = "REPLACE_ME"      # 読み戻し不可のため手動指定（TF_VAR_neon_password でも可）

# WAF レート制限を適用する独自ドメインのゾーン ID。
# 空（未指定）のままなら WAF ルール(waf.tf)は作成されない。ドメイン確定後に設定する。
# zone_id = "REPLACE_ME"
